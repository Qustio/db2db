{
	"version": 6,
	"configurePresets": [
		{
			"name": "base",
			"hidden": true,
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/out/${presetName}",
			"installDir": "${sourceDir}/out/${presetName}/install",
			"architecture": {
				"value": "x64",
				"strategy": "external"
			},
			"cacheVariables": {
				"CMAKE_C_COMPILER": "clang",
				"CMAKE_CXX_COMPILER": "clang++",
				"CMAKE_RC_COMPILER": "llvm-rc",
				"LLVM_COV": "llvm-cov",
				"LLVM_PROFDATA": "llvm-profdata"
			}
		},
		{
			"name": "release",
			"displayName": "x64 Release",
			"inherits": "base",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG -g",
				"CMAKE_C_FLAGS_RELEASE": "-O3 -DNDEBUG -g"
			}
		},
		{
			"name": "srelease",
			"displayName": "x64 SRelease",
			"inherits": "base",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"CMAKE_CXX_FLAGS_RELEASE": "-Os",
				"CMAKE_C_FLAGS_RELEASE": "-Os"
			}
		},
		{
			"name": "debug",
			"displayName": "x64 Debug",
			"description": "x64 Debug build with coverage",
			"inherits": "base",
			"cacheVariables": {
				"ENABLE_COVERAGE": "ON",
				"CMAKE_BUILD_TYPE": "Debug"
			}
		}
	],
	"buildPresets": [
		{
			"name": "release",
			"configurePreset": "release"
		},
		{
			"name": "srelease",
			"configurePreset": "srelease"
		},
		{
			"name": "debug",
			"configurePreset": "debug"
		}
	],
	"testPresets": [
		{
			"name": "release",
			"configurePreset": "release"
		},
		{
			"name": "srelease",
			"configurePreset": "srelease"
		},
		{
			"name": "debug",
			"configurePreset": "debug"
		}
	],
	"packagePresets": [
		{
			"name": "release",
			"configurePreset": "release",
			"generators": [
				"ZIP"
			]
		},
		{
			"name": "srelease",
			"configurePreset": "srelease",
			"generators": [
				"ZIP"
			]
		}
	]
}